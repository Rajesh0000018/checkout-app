# ─────────────────────────────────────────────────────────────────────────────
# CheckoutOS — environment variable reference
# Copy to .env and adjust values for your local setup.
# Never commit a real .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development

# ── Service ports ─────────────────────────────────────────────────────────────
# Required by docker-compose.yml for port mapping and inter-service URLs.
GATEWAY_PORT=5000
CHECKOUT_PORT=5001
PRICING_PORT=5002
INVENTORY_PORT=5003
QUOTE_PORT=5004

# ── Service URLs (used by gateway and checkout) ───────────────────────────────
# When running locally without Docker, use localhost.
# When running via docker-compose, use container service names.
CHECKOUT_URL=http://localhost:5001
PRICING_URL=http://localhost:5002
INVENTORY_URL=http://localhost:5003
QUOTE_URL=http://localhost:5004

# ── Timeout ───────────────────────────────────────────────────────────────────
# How long (milliseconds) downstream calls may take before the caller gives up.
REQUEST_TIMEOUT_MS=800

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=checkoutdb
DB_USER=checkoutuser
DB_PASSWORD=checkoutpass

# ── Currency ──────────────────────────────────────────────────────────────────
CURRENCY=GBP
